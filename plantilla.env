# --- PLANTILLA DE CONFIGURACIÓN DE ENTORNO ---
# Copia este archivo a .env y rellena las rutas con tus valores locales.
# NUNCA subas el archivo .env a un repositorio de Git.

# Rutas absolutas a los archivos .parquet
PATH_PROGRAMACION="C:/Users/TuUsuario/Ruta/A/programacion.parquet"
PATH_ESTUDIANTES="C:/Users/TuUsuario/Ruta/A/estudiantes.parquet"
PATH_DOCENTES="C:/Users/TuUsuario/Ruta/A/docentes.parquet"

# Directorios base para archivos adjuntos
PATH_ADJUNTOS_ALUMNOS="C:/Users/TuUsuario/Ruta/A/adjuntos_alumnos"
PATH_ADJUNTOS_DOCENTES="C:/Users/TuUsuario/Ruta/A/adjuntos_docentes"

# Configuración de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"
